pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/heviiiiiii/HR-System.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('qiu_project') {
                    bat 'docker build -t heviiiiiii/app .'
                }
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker rm -f app-container || exit 0'
                bat 'docker run -d -p 9090:80 --name app-container heviiiiiii/app'
            }
        }

        stage('Test Application') {
            steps {
                echo 'Checking if container is running...'
                bat 'docker ps'

                echo 'Checking application accessibility...'
                bat 'curl -f http://localhost:9090/login.php'
            }
        }

        stage('Docker Login & Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat 'docker login -u %USER% -p %PASS%'
                    bat 'docker push heviiiiiii/app'
                }
            }
        }
    }
}
